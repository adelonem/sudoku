        "If %@ also kept only %@, the rectangle could be completed in two different ways." : {
            "comment" : "A hint that a cell can only contain one of two possible digits. The argument is the string “R%1$argC%2$arg”.",
            "isCommentAutoGenerated" : true,
            "localizations" : {
                "en" : {
                    "stringUnit" : {
                        "state" : "new",
                        "value" : "If %1$@ also kept only %2$@, the rectangle could be completed in two different ways."
                    }
                },
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Si %1$@ ne gardait aussi que %2$@, le rectangle pourrait être complété de deux façons différentes."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "如果%1$@也只保留%2$@，这个矩形就可能以两种不同方式完成。"
                    }
                }
            }
        },
        "If %lld were elsewhere in column %lld, box (%lld,%lld) would have no room for it." : {
            "localizations" : {
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Si le %1$lld était ailleurs dans la colonne %2$lld, la boîte (%3$lld,%4$lld) n'aurait plus de place pour lui."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "如果%1$lld在第%2$lld列的其他位置，宫(%3$lld,%4$lld)将无处放置它。"
                    }
                }
            }
        },
        "If %lld were elsewhere in row %lld, box (%lld,%lld) would have no room for it." : {
            "localizations" : {
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Si le %1$lld était ailleurs dans la ligne %2$lld, la boîte (%3$lld,%4$lld) n'aurait plus de place pour lui."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "如果%1$lld在第%2$lld行的其他位置，宫(%3$lld,%4$lld)将无处放置它。"
                    }
                }
            }
        },
        "If the same digit appears twice in a row, column, or box, the grid is incorrect." : {
            "comment" : "Description of a conflict in a Sudoku grid.",
            "isCommentAutoGenerated" : true,
            "localizations" : {
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Si le même chiffre apparaît deux fois dans une ligne, une colonne ou un bloc, la grille est incorrecte."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "如果同一个数字在某一行、某一列或某个宫格中出现两次，棋盘就是错误的。"
                    }
                }
            }
        },
        "In %@, digit %lld can only be placed at row %lld, column %lld." : {
            "localizations" : {
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Dans %1$@, le chiffre %2$lld ne peut être placé qu'en ligne %3$lld, colonne %4$lld."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "在%1$@中，数字%2$lld只能放在第%3$lld行第%4$lld列。"
                    }
                }
            }
        },
        "In box (%lld,%lld), %lld is confined to column %lld: it can be eliminated from the rest of this column." : {
            "localizations" : {
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Dans la boîte (%1$lld,%2$lld), le %3$lld est confiné à la colonne %4$lld : il peut être éliminé du reste de cette colonne."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
