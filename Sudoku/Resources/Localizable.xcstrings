                    }
                }
            }
        },
        "Wings %@ and %@ together cover the same three digits and both include %lld." : {
            "comment" : "\"Wings\" are the two cells that are in the same 3x3 block as the pivot. The first argument is the string “R%1$argC%2$arg”. The second argument is the string “R%1$argC%2$arg”.",
