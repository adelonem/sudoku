        "Forcing Chains" : {
            "localizations" : {
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Chaînes forcées"
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "强制链"
                    }
                }
            }
        },
        "Forcing Chains: a hypothesis at (%lld,%lld) leads to a contradiction — %lld is certain at (%lld,%lld)." : {
            "extractionState" : "stale",
            "localizations" : {
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Chaînes forcées : une hypothèse en (%1$lld,%2$lld) mène à une contradiction — %3$lld est certain en (%4$lld,%5$lld)."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "强制链：在(%1$lld,%2$lld)的假设导致矛盾——%3$lld确定在(%4$lld,%5$lld)。"
                    }
                }
            }
        },
        "Forcing Chains: assuming %lld at row %lld, column %lld leads to a contradiction, so %lld can be eliminated from this cell." : {
            "comment" : "\"Forcing Chains: assuming 5 at row 1, column 1 leads to a contradiction, so 5 can be eliminated from this cell.\"",
            "isCommentAutoGenerated" : true,
            "localizations" : {
                "en" : {
                    "stringUnit" : {
                        "state" : "new",
                        "value" : "Forcing Chains: assuming %1$lld at row %2$lld, column %3$lld leads to a contradiction, so %4$lld can be eliminated from this cell."
                    }
                },
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Chaînes forcées : supposer %1$lld à la ligne %2$lld, colonne %3$lld mène à une contradiction, donc %4$lld peut être éliminé de cette cellule."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "强制链：假设第%2$lld行第%3$lld列为%1$lld会导致矛盾，因此可以从该单元格删除%4$lld。"
                    }
                }
            }
        },
        "Forcing Chains: regardless of the values at (%lld,%lld), cell (%lld,%lld) is always %lld." : {
            "extractionState" : "stale",
            "localizations" : {
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Chaînes forcées : quelles que soient les valeurs de (%1$lld,%2$lld), la cellule (%3$lld,%4$lld) vaut toujours %5$lld."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "强制链：无论(%1$lld,%2$lld)的值如何，单元格(%3$lld,%4$lld)始终为%5$lld。"
                    }
                }
            }
        },
        "Forcing Chains: whatever the value at row %lld, column %lld, row %lld, column %lld is always %lld." : {
            "comment" : "A hint that a given digit is guaranteed to be in a specific position, given that the same digit is guaranteed to be in other positions, regardless of the value in a different position.",
            "isCommentAutoGenerated" : true,
            "localizations" : {
                "en" : {
                    "stringUnit" : {
                        "state" : "new",
                        "value" : "Forcing Chains: whatever the value at row %1$lld, column %2$lld, row %3$lld, column %4$lld is always %5$lld."
                    }
                },
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Chaînes forcées : quelle que soit la valeur en ligne %1$lld, colonne %2$lld, la ligne %3$lld, colonne %4$lld est toujours %5$lld."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "强制链：无论第%1$lld行第%2$lld列取何值，第%3$lld行第%4$lld列始终是%5$lld。"
                    }
                }
            }
