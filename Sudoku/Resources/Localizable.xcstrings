        },
        "Whatever the pivot becomes, one wing must take %lld, so common peers %@ cannot keep %lld." : {
            "localizations" : {
                "en" : {
                    "stringUnit" : {
                        "state" : "new",
                        "value" : "Whatever the pivot becomes, one wing must take %1$lld, so common peers %2$@ cannot keep %3$lld."
                    }
                },
                "fr" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "Quelle que soit la valeur du pivot, une aile doit prendre %1$lld, donc les pairs communs %2$@ ne peuvent pas garder %3$lld."
                    }
                },
                "zh-Hans" : {
                    "stringUnit" : {
                        "state" : "translated",
                        "value" : "无论枢轴取何值，必有一个翼取%1$lld，因此共同同伴格%2$@不能保留%3$lld。"
                    }
                }
            }
        },
        "When you are confident, a double tap writes the selected number into the grid." : {
